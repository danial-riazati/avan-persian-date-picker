{
  "name": "@avan-persian/holidays",
  "version": "0.1.1",
  "description": "Iran public holidays for Avan Persian Date Picker",
  "license": "MIT",
  "author": "Danial Riazati (https://github.com/danial-riazati)",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danial-riazati/avan-persian-date-picker.git",
    "directory": "packages/holidays"
  },
  "homepage": "https://github.com/danial-riazati/avan-persian-date-picker#readme",
  "bugs": {
    "url": "https://github.com/danial-riazati/avan-persian-date-picker/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./1404": "./data/1404.json",
    "./1405": "./data/1405.json",
    "./1406": "./data/1406.json",
    "./fixed-solar": "./data/fixed-solar.json"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@avan-persian/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsdown": "^0.9.9",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "avan",
    "iran",
    "holidays",
    "jalali",
    "persian",
    "nowruz",
    "shamsi"
  ]
}
