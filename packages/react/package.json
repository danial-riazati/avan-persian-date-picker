{
  "name": "@avan-persian/react",
  "version": "0.1.1",
  "description": "React components for Avan Persian Date Picker",
  "license": "MIT",
  "author": "Danial Riazati (https://github.com/danial-riazati)",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danial-riazati/avan-persian-date-picker.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/danial-riazati/avan-persian-date-picker#readme",
  "bugs": {
    "url": "https://github.com/danial-riazati/avan-persian-date-picker/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client.css": "./dist/client.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@avan-persian/core": "workspace:*",
    "@avan-persian/holidays": "workspace:*",
    "date-fns-jalali": "^4.1.0-0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.9.9",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "avan",
    "react",
    "nextjs",
    "jalali",
    "persian",
    "shamsi",
    "datepicker",
    "date-picker",
    "calendar",
    "rtl",
    "farsi"
  ]
}
