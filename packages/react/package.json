{
  "name": "@avan/react",
  "version": "0.0.0",
  "description": "React components for Avan Persian Date Picker",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/avan-persian-date-picker.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/YOUR_USERNAME/avan-persian-date-picker#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/avan-persian-date-picker/issues"
  },
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@avan/core": "workspace:*",
    "@avan/holidays": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.9.9",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "avan",
    "react",
    "nextjs",
    "jalali",
    "persian",
    "shamsi",
    "datepicker",
    "date-picker",
    "calendar",
    "rtl",
    "farsi"
  ]
}
