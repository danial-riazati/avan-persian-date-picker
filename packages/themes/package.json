{
  "name": "@avan-persian/themes",
  "version": "0.1.0",
  "description": "Design tokens and CSS themes for Avan Persian Date Picker",
  "license": "MIT",
  "author": "Danial Riazati (https://github.com/danial-riazati)",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danial-riazati/avan-persian-date-picker.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/danial-riazati/avan-persian-date-picker#readme",
  "bugs": {
    "url": "https://github.com/danial-riazati/avan-persian-date-picker/issues"
  },
  "exports": {
    "./fonts.css": "./src/fonts.css",
    "./default.css": "./src/default.css",
    "./dark.css": "./src/dark.css",
    "./tailwind": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js"
    }
  },
  "files": [
    "fonts",
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsdown": "^0.9.9",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "avan",
    "css",
    "tailwind",
    "theme",
    "jalali",
    "persian",
    "shamsi"
  ]
}
