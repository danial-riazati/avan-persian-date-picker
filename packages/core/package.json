{
  "name": "@avan-persian/core",
  "version": "0.1.0",
  "description": "Headless Jalali (Persian) date utilities for Avan Persian Date Picker",
  "license": "MIT",
  "author": "Danial Riazati (https://github.com/danial-riazati)",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danial-riazati/avan-persian-date-picker.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/danial-riazati/avan-persian-date-picker#readme",
  "bugs": {
    "url": "https://github.com/danial-riazati/avan-persian-date-picker/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./convert": {
      "types": "./dist/convert.d.ts",
      "import": "./dist/convert.js"
    },
    "./grid": {
      "types": "./dist/grid.d.ts",
      "import": "./dist/grid.js"
    },
    "./business": {
      "types": "./dist/business.d.ts",
      "import": "./dist/business.js"
    },
    "./digits": {
      "types": "./dist/digits.d.ts",
      "import": "./dist/digits.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "date-fns-jalali": "^4.1.0-0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsdown": "^0.9.9",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "avan",
    "jalali",
    "persian",
    "shamsi",
    "calendar",
    "date-fns",
    "typescript"
  ]
}
