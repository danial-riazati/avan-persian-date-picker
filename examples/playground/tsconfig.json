{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@avan-persian/core": ["../../packages/core/src/index.ts"],
      "@avan-persian/holidays": ["../../packages/holidays/src/index.ts"],
      "@avan-persian/react/client": ["../../packages/react/src/client.ts"]
    }
  },
  "include": ["src"]
}
